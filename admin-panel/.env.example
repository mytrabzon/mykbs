# Admin panel girişi (Panel Şifresi). Production: backend ADMIN_SECRET ile birebir aynı olmalı.
NEXT_PUBLIC_ADMIN_SECRET=

# Backend API URL (e-posta/şifre ile giriş için)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
API_URL=http://localhost:8080/api

# Supabase — Production build öncesi mutlaka doldur. Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opsiyonel
NEXT_PUBLIC_BASE_PATH=
