# Backend = Supabase (Edge Functions). Detay: ENV_BACKEND.md
# Zorunlu (aynı isimlerle mobile/.env içinde doldurun):

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Anon key: Dashboard → Project Settings → API → anon public (tam JWT, tek satır)
# URL: aynı sayfada Project URL

# İsteğe bağlı
# EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1
