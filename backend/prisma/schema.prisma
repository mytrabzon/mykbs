// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Tesis (Otel) Modeli
model Tesis {
  id                String   @id @default(cuid())
  tesisAdi          String
  yetkiliAdSoyad    String
  telefon           String   // WhatsApp numarası
  email             String
  il                String
  ilce              String
  adres             String
  odaSayisi         Int
  tesisTuru         String   // otel, pansiyon, apart, diğer
  vergiNo           String?
  unvan             String?
  web               String?
  instagram         String?
  not               String?
  
  // KBS Bilgileri
  kbsTuru           String?  // jandarma, polis
  kbsTesisKodu      String?
  kbsWebServisSifre String?  @map("kbs_web_servis_sifre")
  ipKisitAktif      Boolean  @default(false)
  ipAdresleri       String   @default("") // SQLite için string olarak değiştirildi
  
  // Aktivasyon
  tesisKodu         String   @unique
  aktivasyonSifre   String?
  aktivasyonSifreExpiresAt DateTime?
  durum             String   @default("incelemede") // incelemede, onaylandi, aktif, pasif
  
  // Paket ve Kota (deneme: 3 gün 100 bildirim; starter/pro/business/enterprise: kredi bitene kadar)
  paket             String   @default("deneme") // deneme, starter, pro, business, enterprise
  kota              Int      @default(100)     // deneme=100, paket satın alınca paket kredisi
  kullanilanKota    Int      @default(0)
  kotaResetTarihi   DateTime?
  trialEndsAt       DateTime?                  // deneme süresi bitişi (3 gün); paket alınca null
  
  // İlişkiler
  kullanicilar      Kullanici[]
  odalar            Oda[]
  bildirimler       Bildirim[]
  loglar            Log[]
  hatalar           Hata[]
  auditLogs         AuditLog[]
  siparisler        Siparis[]
  hotelStaffs       HotelStaff[]
  guests            Guest[]
  stays             Stay[]
  kbsSubmissions    KbsSubmission[]
  okutulanBelgeler  OkutulanBelge[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Okutulan kimlik/pasaport kayıtları — ayarlarda listelenir, foto opsiyonel
model OkutulanBelge {
  id             String   @id @default(cuid())
  tesisId        String
  kullaniciId    String?  // Kim okuttu (Supabase user id veya backend kullanici id)
  belgeTuru      String   // kimlik, pasaport
  ad             String
  soyad          String
  kimlikNo       String?  // TC (maskeli saklanacak)
  pasaportNo     String?  // Pasaport no (maskeli)
  belgeNo        String?  // MRZ documentNumber (tek alan: kimlik veya pasaport no)
  dogumTarihi    String?  // YYYY-MM-DD veya DD.MM.YYYY
  uyruk          String?
  photoUrl       String?  // Yüklenen belge/ön yüz foto path
  createdAt      DateTime @default(now())

  tesis          Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)

  @@index([tesisId])
  @@index([createdAt])
}

// Sipariş (Paket satışı) — mobil "Satın Al" veya admin manuel atama
model Siparis {
  id          String   @id @default(cuid())
  siparisNo  String   @unique  // Okunabilir: ORD-2024-0001
  tesisId    String
  paket      String   // starter, pro, business, enterprise
  tutarTL    Int      // Kuruş değil, TL
  kredi      Int      // Bildirim kotası
  durum      String   @default("pending") // pending, odendi, iptal
  odemeAt    DateTime? // Ödeme alındığında
  adminNot   String?  // Admin notu (havale ref no vb.)
  tesis      Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([tesisId])
  @@index([durum])
  @@index([createdAt])
}

// Kullanıcı Modeli
model Kullanici {
  id                String   @id @default(cuid())
  tesisId           String
  adSoyad           String
  telefon           String
  email             String?
  sifre             String?  // Hash'lenmiş şifre (email/telefon girişi için)
  pin               String?  // Hash'lenmiş PIN (eski sistem)
  biyometriAktif    Boolean  @default(false)
  rol               String   @default("resepsiyon") // sahip, yonetici, resepsiyon
  
  // Yetkiler
  checkInYetki      Boolean  @default(true)
  odaDegistirmeYetki Boolean @default(true)
  bilgiDuzenlemeYetki Boolean @default(true)
  
  // Tesis kodu + PIN ile giriş: admin onayı gerekir (onaydan sonra yeşil, önce gri)
  girisOnaylandi    Boolean  @default(false)
  girisTalepAt      DateTime? // Son giriş talebi zamanı (admin listesinde göstermek için)

  // Profil (topluluk/görünen ad – e-posta, telefon, tesis kodu farketmez hepsi kullanabilir)
  displayName       String?
  title             String?  // Ünvan / pozisyon
  avatarUrl         String?

  // Hesap silme talebi (7 gün içinde kalıcı silinir; bu sürede geri alınabilir)
  deletion_requested_at DateTime?

  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  hotelStaffs       HotelStaff[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tesisId])
  @@index([email])
  @@index([telefon])
  @@index([deletion_requested_at])
}

// Oda Modeli
model Oda {
  id                String   @id @default(cuid())
  tesisId           String
  odaNumarasi       String
  odaTipi           String   // 1+1, 2 kişilik, vb.
  kapasite          Int
  fotograf          String?
  not               String?
  durum             String   @default("bos") // bos, dolu
  
  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  misafirler        Misafir[]
  stays             Stay[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([tesisId, odaNumarasi])
  @@index([tesisId])
}

// Misafir Modeli
model Misafir {
  id                String   @id @default(cuid())
  odaId             String
  tesisId           String
  ad                String   // 1. ad
  ad2               String?  // 2. ad (opsiyonel)
  soyad             String
  kimlikNo          String?  // TC no (maskeli saklanacak)
  pasaportNo        String?  // Pasaport no (maskeli saklanacak)
  dogumTarihi       DateTime
  uyruk             String   // Ülke / uyruk
  misafirTipi       String?  // tc_vatandasi | ykn | yabanci (Jandarma/Polis bildirimi için)
  girisTarihi       DateTime @default(now())
  cikisTarihi       DateTime?
  email             String?  // Admin: atanan e-posta (misafir bildirimi / davet)
  
  oda               Oda      @relation(fields: [odaId], references: [id], onDelete: Cascade)
  bildirimler       Bildirim[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([tesisId])
  @@index([odaId])
  @@index([email])
}

// KBS Bildirim Modeli
model Bildirim {
  id                String   @id @default(cuid())
  tesisId           String
  misafirId         String
  durum             String   // basarili, beklemede, hatali
  hataMesaji        String?
  denemeSayisi      Int      @default(0)
  sonDenemeTarihi   DateTime?
  kbsTuru           String   // jandarma, polis
  kbsYanit          String?  // KBS'den gelen yanıt (SQLite için string)
  
  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  misafir           Misafir  @relation(fields: [misafirId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([tesisId])
  @@index([misafirId])
  @@index([durum])
}

// Log Modeli
model Log {
  id                String   @id @default(cuid())
  tesisId           String
  islem             String   // check-in, check-out, oda-degistir, ayar-degistir
  detay             String?  // SQLite için string
  kullaniciId       String?
  basarili          Boolean  @default(true)
  
  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  
  @@index([tesisId])
  @@index([createdAt])
}

// Hata Modeli
model Hata {
  id                String   @id @default(cuid())
  tesisId           String
  bildirimId        String?
  hataTipi          String   // kbs-baglanti, kbs-yanit, ocr, nfc, diger
  hataMesaji        String
  durum             String   @default("acik") // acik, cozuldu
  cozumNotu         String?
  
  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([tesisId])
  @@index([durum])
}

// Audit Log Modeli
model AuditLog {
  id                String   @id @default(cuid())
  tesisId           String
  kullaniciId       String?
  islem             String   // kim, ne zaman, neyi değiştirdi
  eskiDeger         String?  // SQLite için string
  yeniDeger         String?  // SQLite için string
  
  tesis             Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  
  @@index([tesisId])
  @@index([createdAt])
}

// OTP (One-Time Password) Modeli
model OTP {
  id                String   @id @default(cuid())
  telefon           String
  otp               String   // 6 haneli OTP kodu
  kullaniciId       String?  // Eğer kayıtlı kullanıcı varsa
  islemTipi         String   // kayit, giris
  durum             String   @default("beklemede") // beklemede, dogrulandi, iptal
  denemeSayisi      Int      @default(0)
  expiresAt         DateTime // OTP süresi (5 dakika)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([telefon])
  @@index([otp])
  @@index([expiresAt])
  @@index([durum])
}

// KYC Doğrulama (MRZ / NFC roadmap)
model KycVerification {
  id              String   @id @default(cuid())
  userId          String?  // Opsiyonel: backend kullanıcı eşleşirse
  type            String   // MRZ
  passportLast4   String   // Son 4 karakter (maskeli)
  birthDate       String   // ISO
  expiryDate      String   // ISO
  issuingCountry String?
  status          String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Otel personeli: Tesis–Kullanıcı eşleşmesi, rol, foto görüntüleme yetkisi
model HotelStaff {
  id             String   @id @default(cuid())
  tesisId        String
  kullaniciId    String
  role           String   @default("staff") // owner, manager, staff
  canViewPhotos  Boolean  @default(true)
  tesis          Tesis    @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  kullanici      Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tesisId, kullaniciId])
  @@index([tesisId])
  @@index([kullaniciId])
}

// Otel içi misafir profili: foto + identity_hash (belge no saklanmaz), 30 gün sonra silinir
model Guest {
  id             String   @id @default(cuid())
  tesisId        String
  displayName    String?
  photoUrl       String?
  photoBlurhash  String?
  identityHash   String   // HMAC(docType+docNo+birthDate); eşleştirme için
  expiresAt      DateTime
  tesis          Tesis   @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  stays          Stay[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tesisId])
  @@index([expiresAt])
  @@index([identityHash, tesisId])
}

// Konaklama kaydı (guest nullable; MRZ okunmadıysa geçici stay)
model Stay {
  id             String   @id @default(cuid())
  tesisId        String
  guestId        String?
  odaId          String?
  roomNo         String
  checkInAt      DateTime @default(now())
  checkOutAt     DateTime?
  usageType      String   // konaklama, gunici, depremzede
  kbsStatus      String   @default("PENDING") // PENDING, SENT, ACCEPTED, REJECTED
  kbsLastError   String?
  expiresAt      DateTime
  tesis          Tesis   @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  guest          Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)
  oda            Oda?    @relation(fields: [odaId], references: [id], onDelete: SetNull)
  kbsSubmissions KbsSubmission[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tesisId])
  @@index([guestId])
  @@index([odaId])
  @@index([checkInAt])
  @@index([expiresAt])
}

// KBS'ye gönderilen payload (audit); PII minimize
model KbsSubmission {
  id               String   @id @default(cuid())
  tesisId          String
  stayId           String
  citizenshipType  String   // TC, YKN, FOREIGN
  payloadJson      Json
  sentAt           DateTime @default(now())
  responseCode     String?
  responseMessage  String?
  correlationId    String?
  tesis            Tesis   @relation(fields: [tesisId], references: [id], onDelete: Cascade)
  stay             Stay    @relation(fields: [stayId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([tesisId])
  @@index([stayId])
  @@index([sentAt])
  @@index([correlationId])
}

