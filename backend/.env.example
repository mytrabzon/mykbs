# Backend ortam değişkenleri — kopyala: cp .env.example .env — sonra değerleri doldur.
# .env dosyası git'e GİRMEZ (.gitignore). Gerçek key'leri sadece .env içinde tut.

PORT=8080
HOST=0.0.0.0
NODE_ENV=development
# Supabase PostgreSQL (Dashboard → Settings → Database → Connection string → URI)
# Yerel: aynı URL veya kendi Postgres. Railway: bu değişkeni mutlaka ekleyin.
# Pooler kullanıyorsanız (pooler.supabase.com): URL sonuna ?pgbouncer=true ekleyin veya port 6543 (session) kullanın.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.XXXX.supabase.co:5432/postgres"

JWT_SECRET=<güçlü-rastgele-string-en-az-32-karakter>
JWT_EXPIRES_IN=7d

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key_Dashboard_Settings_API>

# ADMIN_KULLANICI_ID=1
# KBS: Jandarma/Polis web servis URL'leri. İkisi de boşsa mock kullanılır (gerçek KBS'ye istek gitmez).
# Bağlantı için: tesis kodu + web servis şifresi + KBS tarafında sunucu IP'si tanımlı olmalı (docs/KBS_BAGLANTI_GEREKSINIMLERI.md).
# JANDARMA_KBS_URL=https://...
# POLIS_KBS_URL=https://...
SYNC_BRANCH_SECRET=<sync_secret>
ADMIN_SECRET=<admin_secret>

# Railway deploy için (opsiyonel)
# RAILWAY_TOKEN=<railway_project_token>
